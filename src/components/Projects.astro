---
import GitHub from "./icons/GitHub.astro"
import NextJS from "./icons/NextJS.astro"
import Tailwind from "./icons/Tailwind.astro"
import Code from "./icons/Code.astro"
import System from "./icons/System.astro"
import ExternalLink from "./icons/ExternalLink.astro"
import LinkButton from "./LinkButton.astro"
import projectsData from "@/data/projects.json"

const TAGS: Record<string, { key: string; name: string; class: string; icon: any }> = {
  NEXT: {
    key: "NEXT",
    name: "Next.js",
    class: "bg-black text-white",
    icon: NextJS,
  },
  TAILWIND: {
    key: "TAILWIND",
    name: "Tailwind CSS",
    class: "bg-[#003159] text-white",
    icon: Tailwind,
  },
  WEB: {
    key: "WEB",
    name: "Web",
    class: "bg-slate-800 text-white",
    icon: Code,
  },
  MOBILE: {
    key: "MOBILE",
    name: "Multiplataforma",
    class: "bg-violet-700 text-white",
    icon: System,
  },
  UTN: {
    key: "UTN",
    name: "UTN FRBA",
    class: "bg-[#a11f2d] text-white",
    icon: System,
  },
  SECURITY: {
    key: "SECURITY",
    name: "Seguridad",
    class: "bg-amber-400 text-black",
    icon: Code,
  },
  LMS: {
    key: "LMS",
    name: "LMS",
    class: "bg-[#f5bd1f] text-black",
    icon: Code,
  },
  WORDPRESS: {
    key: "WORDPRESS",
    name: "WordPress",
    class: "bg-[#21759b] text-white",
    icon: Code,
  },
  PROJECT: {
    key: "PROJECT",
    name: "Proyecto",
    class: "bg-gray-600 text-white",
    icon: Code,
  },
  HEALTH: {
    key: "HEALTH",
    name: "Salud",
    class: "bg-emerald-600 text-white",
    icon: System,
  },
}

const PROJECTS = projectsData.map((project, index) => ({
  index,
  ...project,
  tags: project.tags.map((key) => TAGS[key]),
  categories: [
    ...(project.tags.includes("AI") || project.tags.includes("IA") ? ["ia"] : []),
    ...(project.tags.includes("WEB") ? ["web"] : []),
    ...(project.tags.includes("MOBILE") ? ["mobile"] : []),
  ],
}))
---

<div class="flex flex-col gap-y-10" id="projects-filter-root">
  <div class="flex flex-wrap items-center gap-3" role="tablist" aria-label="Filtrar proyectos por categoria" data-i18n-attr="aria-label:projects.filterAria">
    <button type="button" data-filter="all" class="projects-filter-btn is-active rounded-full border border-violet-300/80 bg-violet-100/80 px-4 py-2 text-sm font-semibold text-violet-700 dark:border-violet-500/50 dark:bg-violet-500/20 dark:text-violet-200" data-i18n="projects.filter.all">
      Todos
    </button>
    <button type="button" data-filter="ia" class="projects-filter-btn rounded-full border border-slate-300/80 bg-white/80 px-4 py-2 text-sm font-semibold text-slate-700 dark:border-slate-700 dark:bg-slate-900/80 dark:text-slate-200" data-i18n="projects.filter.ia">
      IA
    </button>
    <button type="button" data-filter="web" class="projects-filter-btn rounded-full border border-slate-300/80 bg-white/80 px-4 py-2 text-sm font-semibold text-slate-700 dark:border-slate-700 dark:bg-slate-900/80 dark:text-slate-200" data-i18n="projects.filter.web">
      Web
    </button>
    <button type="button" data-filter="mobile" class="projects-filter-btn rounded-full border border-slate-300/80 bg-white/80 px-4 py-2 text-sm font-semibold text-slate-700 dark:border-slate-700 dark:bg-slate-900/80 dark:text-slate-200" data-i18n="projects.filter.mobile">
      Mobile
    </button>
  </div>

  <p id="projects-empty-state" class="hidden text-sm text-slate-600 dark:text-slate-300" data-i18n="projects.emptyState">
    No hay proyectos cargados en esta categoria por ahora.
  </p>

  <div class="flex flex-col gap-y-16" id="projects-list">
  {
    PROJECTS.map(({ image, title, description, tags, link, github, categories, index }) => (
    <article class="project-item flex flex-col space-x-0 space-y-6 group md:flex-row md:space-x-10 md:space-y-0" data-categories={categories.join(",") || "uncategorized"}>
  <div class="w-full md:w-1/2">
    <div class="relative flex flex-col items-center col-span-6 row-span-5 gap-8 transition-all duration-500 ease-in-out transform shadow-xl overflow-hidden rounded-xl sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-[0_20px_60px_-10px_rgba(167,139,250,0.2)] lg:border lg:border-gray-800 lg:hover:border-violet-400/30 lg:hover:bg-gray-800/50 aspect-[16/10] max-h-[420px]">
      <img alt={title} class="object-contain object-center w-full h-full p-2 bg-white/60 dark:bg-slate-900/60 transition duration-500 md:group-hover:scale-[1.01]" loading="lazy" src={image} />
      <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" aria-hidden="true"></div>
    </div>
  </div>

  <div class="w-full md:w-1/2 md:max-w-lg flex flex-col justify-center">
    <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">
      <span data-i18n={`projects.items.${index}.title`}>{title}</span>
    </h3>
    <ul class="flex flex-row flex-wrap mt-3 gap-2">
      {tags.map((tag) => (
        <li>
          <span
            class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2`}
          >
            <tag.icon class="size-4" />
            <span data-i18n={`projects.tags.${tag.key}`}>{tag.name}</span>
          </span>
        </li>
      ))}
    </ul>

    <p class="mt-3 text-gray-700 dark:text-gray-400 text-pretty">
      <span data-i18n={`projects.items.${index}.description`}>{description}</span>
    </p>
    <footer class="flex items-center mt-4 gap-x-4">
      {github && (
        <LinkButton href={github}>
          <GitHub class="size-5" />
          <span data-i18n="projects.code">Code</span>
        </LinkButton>
      )}
      {link && (
        <LinkButton href={link}>
          <ExternalLink class="size-4" />
          <span data-i18n="projects.preview">Preview</span>
        </LinkButton>
      )}
    </footer>
  </div>
</article>
    ))
  }
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const root = document.getElementById("projects-filter-root")
    if (!root) return

    const buttons = root.querySelectorAll<HTMLButtonElement>(".projects-filter-btn")
    const items = root.querySelectorAll<HTMLElement>(".project-item")
    const emptyState = document.getElementById("projects-empty-state")

    const setActiveButton = (activeFilter: string) => {
      buttons.forEach((btn) => {
        const isActive = btn.dataset.filter === activeFilter
        btn.classList.toggle("is-active", isActive)
        btn.classList.toggle("border-violet-300/80", isActive)
        btn.classList.toggle("bg-violet-100/80", isActive)
        btn.classList.toggle("text-violet-700", isActive)
        btn.classList.toggle("dark:border-violet-500/50", isActive)
        btn.classList.toggle("dark:bg-violet-500/20", isActive)
        btn.classList.toggle("dark:text-violet-200", isActive)

        btn.classList.toggle("border-slate-300/80", !isActive)
        btn.classList.toggle("bg-white/80", !isActive)
        btn.classList.toggle("text-slate-700", !isActive)
        btn.classList.toggle("dark:border-slate-700", !isActive)
        btn.classList.toggle("dark:bg-slate-900/80", !isActive)
        btn.classList.toggle("dark:text-slate-200", !isActive)
      })
    }

    const applyFilter = (filter: string) => {
      let visibleCount = 0

      items.forEach((item) => {
        const categories = (item.dataset.categories || "").split(",")
        const shouldShow = filter === "all" || categories.includes(filter)
        item.classList.toggle("hidden", !shouldShow)
        if (shouldShow) visibleCount += 1
      })

      if (emptyState) {
        emptyState.classList.toggle("hidden", visibleCount > 0)
      }

      setActiveButton(filter)
    }

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const filter = button.dataset.filter || "all"
        applyFilter(filter)
      })
    })

    applyFilter("all")
  })
</script>



