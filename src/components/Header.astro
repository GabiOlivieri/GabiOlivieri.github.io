---
import ThemeToggle from "./ThemeToggle.astro"
import es from "@/data/i18n/es.json"
import en from "@/data/i18n/en.json"

const translations = { es, en }

const navItems = [
  {
    title: es.nav.experiencia,
    i18nKey: "nav.experiencia",
    label: "experiencia",
    url: "/#experiencia",
  },
  {
    title: es.nav.formacion,
    i18nKey: "nav.formacion",
    label: "formacion",
    url: "/#formacion",
  },
  {
    title: es.nav.stack,
    i18nKey: "nav.stack",
    label: "stack",
    url: "/#stack",
  },
  {
    title: es.nav.certificaciones,
    i18nKey: "nav.certificaciones",
    label: "certificaciones",
    url: "/#certificaciones",
  },
  {
    title: es.nav.proyectos,
    i18nKey: "nav.proyectos",
    label: "proyectos",
    url: "/#proyectos",
  },
  {
    title: es.nav.blog,
    i18nKey: "nav.blog",
    label: "blog",
    url: "/#blog",
  },
]
---

<header class="fixed top-0 z-20 w-full mt-4 px-4">
  <nav
    class="header-nav hidden md:flex gap-x-1 px-4 py-1.5 text-sm font-medium rounded-full text-gray-600 dark:text-gray-300 justify-center items-center border border-transparent mx-auto w-max"
  >
    {
      navItems.map((link) => (
        <a
          class="nav-link relative block px-3 py-1.5 rounded-full transition-colors duration-200 hover:text-violet-500 dark:hover:text-violet-400"
          aria-label={link.label}
          href={link.url}
        >
          <span data-i18n={link.i18nKey}>{link.title}</span>
        </a>
      ))
    }
    <div class="ml-2 pl-2 border-l border-gray-300/30 dark:border-white/10 inline-flex gap-1">
      <button
        type="button"
        class="lang-btn rounded-full px-2 py-1 text-xs font-semibold transition-colors hover:text-violet-500 dark:hover:text-violet-400"
        data-lang-switch="es"
        data-i18n="lang.es"
        aria-label="Cambiar a español"
      >
        ES
      </button>
      <button
        type="button"
        class="lang-btn rounded-full px-2 py-1 text-xs font-semibold transition-colors hover:text-violet-500 dark:hover:text-violet-400"
        data-lang-switch="en"
        data-i18n="lang.en"
        aria-label="Switch to English"
      >
        EN
      </button>
    </div>
    <div class="ml-2 pl-2 border-l border-gray-300/30 dark:border-white/10">
      <ThemeToggle />
    </div>
  </nav>

  <details class="mobile-nav ml-auto w-fit md:hidden">
    <summary
      class="mobile-toggle list-none grid place-items-center size-11 rounded-full border border-gray-200/70 bg-white/90 text-gray-700 shadow-lg ring-1 ring-white/20 backdrop-blur-md dark:bg-gray-900/90 dark:text-gray-200 dark:border-white/10 dark:ring-white/10"
      aria-label={es.nav.openMenu}
      data-i18n-attr="aria-label:nav.openMenu"
    >
      <span class="hamburger" aria-hidden="true">
        <span class="line line-1"></span>
        <span class="line line-2"></span>
        <span class="line line-3"></span>
      </span>
    </summary>
    <nav class="mobile-menu mt-2 w-[min(18rem,calc(100vw-2rem))] rounded-2xl border border-gray-200/70 bg-white/95 p-2 text-gray-700 shadow-xl ring-1 ring-white/20 backdrop-blur-md dark:bg-gray-900/95 dark:text-gray-200 dark:border-white/10 dark:ring-white/10">
      {
        navItems.map((link) => (
          <a
            class="nav-link block rounded-xl px-3 py-2.5 text-sm font-medium transition-colors duration-200 hover:text-violet-500 dark:hover:text-violet-400"
            aria-label={link.label}
            href={link.url}
          >
            <span data-i18n={link.i18nKey}>{link.title}</span>
          </a>
        ))
      }
      <div class="mt-2 pt-2 border-t border-gray-200/70 dark:border-white/10 flex items-center justify-between">
        <span class="text-xs uppercase tracking-[0.2em] text-gray-500 dark:text-gray-400" data-i18n="lang.selector"
          >Idioma</span
        >
        <div class="inline-flex gap-1">
          <button
            type="button"
            class="lang-btn rounded-full px-2 py-1 text-xs font-semibold transition-colors hover:text-violet-500 dark:hover:text-violet-400"
            data-lang-switch="es"
            data-i18n="lang.es"
            aria-label="Cambiar a español"
          >
            ES
          </button>
          <button
            type="button"
            class="lang-btn rounded-full px-2 py-1 text-xs font-semibold transition-colors hover:text-violet-500 dark:hover:text-violet-400"
            data-lang-switch="en"
            data-i18n="lang.en"
            aria-label="Switch to English"
          >
            EN
          </button>
        </div>
      </div>
      <div class="mt-2 pt-2 border-t border-gray-200/70 dark:border-white/10 flex justify-end">
        <ThemeToggle />
      </div>
    </nav>
  </details>
</header>

<script is:inline define:vars={{ translations }}>
  document.addEventListener("astro:page-load", () => {
    const sections = Array.from(document.querySelectorAll("section[id]"))
    const navItems = document.querySelectorAll("header nav a")
    const mobileNav = document.querySelector(".mobile-nav")
    const langButtons = document.querySelectorAll("[data-lang-switch]")

    const getValueByPath = (obj, path) =>
      path.split(".").reduce((acc, key) => acc?.[key], obj)

    const setLanguageButtonState = (lang) => {
      langButtons.forEach((button) => {
        if (button.dataset.langSwitch === lang) {
          button.classList.add("text-violet-500", "dark:text-violet-400", "bg-violet-400/10")
        } else {
          button.classList.remove("text-violet-500", "dark:text-violet-400", "bg-violet-400/10")
        }
      })
    }

    const applyTranslations = (lang) => {
      const dict = translations[lang] ?? translations.es

      document.documentElement.lang = lang
      document.querySelectorAll("[data-i18n]").forEach((element) => {
        const key = element.getAttribute("data-i18n")
        if (!key) return
        const value = getValueByPath(dict, key)
        if (typeof value === "string") {
          element.textContent = value
        }
      })

      document.querySelectorAll("[data-i18n-html]").forEach((element) => {
        const key = element.getAttribute("data-i18n-html")
        if (!key) return
        const value = getValueByPath(dict, key)
        if (typeof value === "string") {
          element.innerHTML = value
        }
      })

      document.querySelectorAll("[data-i18n-attr]").forEach((element) => {
        const descriptor = element.getAttribute("data-i18n-attr")
        if (!descriptor) return
        const [attrName, key] = descriptor.split(":")
        const value = getValueByPath(dict, key)
        if (attrName && typeof value === "string") {
          element.setAttribute(attrName, value)
        }
      })

      if (typeof dict.page?.title === "string") {
        document.title = dict.page.title
      }

      const descriptionMeta = document.querySelector('meta[name="description"]')
      if (descriptionMeta && typeof dict.page?.description === "string") {
        descriptionMeta.setAttribute("content", dict.page.description)
      }

      setLanguageButtonState(lang)
    }

    const detectLanguage = () => {
      const savedLanguage = localStorage.getItem("site-language")
      if (savedLanguage === "es" || savedLanguage === "en") {
        return savedLanguage
      }

      return navigator.language.toLowerCase().startsWith("en") ? "en" : "es"
    }

    const initialLanguage = detectLanguage()
    applyTranslations(initialLanguage)

    const setActiveNavItem = (sectionId) => {
      navItems.forEach((item) => {
        if (item.getAttribute("aria-label") == sectionId) {
          item.classList.add("text-violet-500", "dark:text-violet-400", "bg-violet-400/10")
          item.classList.remove("text-gray-600", "dark:text-gray-300")
        } else {
          item.classList.remove("text-violet-500", "dark:text-violet-400", "bg-violet-400/10")
          item.classList.add("text-gray-600", "dark:text-gray-300")
        }
      })
    }

    const header = document.querySelector("header")

    const getActivationOffset = () => {
      const headerHeight = header?.getBoundingClientRect().height ?? 0
      return headerHeight + window.innerHeight * 0.2
    }

    const updateActiveSection = () => {
      if (!sections.length) return

      const scrollLine = window.scrollY + getActivationOffset()
      let activeSectionId = sections[0].id

      sections.forEach((section) => {
        if (section.offsetTop <= scrollLine) {
          activeSectionId = section.id
        }
      })

      setActiveNavItem(activeSectionId)
    }

    updateActiveSection()
    window.addEventListener("scroll", updateActiveSection, { passive: true })
    window.addEventListener("resize", updateActiveSection)

    if (mobileNav) {
      const mobileLinks = mobileNav.querySelectorAll("a")

      mobileLinks.forEach((link) => {
        link.addEventListener("click", () => {
          mobileNav.removeAttribute("open")
        })
      })

      document.addEventListener("click", (event) => {
        if (mobileNav.open && event.target instanceof Node && !mobileNav.contains(event.target)) {
          mobileNav.removeAttribute("open")
        }
      })
    }

    langButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const lang = button.dataset.langSwitch === "en" ? "en" : "es"
        localStorage.setItem("site-language", lang)
        applyTranslations(lang)
      })
    })
  })
</script>

<style>
  .mobile-nav > summary::-webkit-details-marker {
    display: none;
  }

  .mobile-nav > summary {
    cursor: pointer;
  }

  .hamburger {
    width: 1.15rem;
    height: 0.95rem;
    display: inline-flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .hamburger .line {
    height: 2px;
    width: 100%;
    border-radius: 9999px;
    background-color: currentColor;
    transform-origin: center;
    transition: transform 220ms ease, opacity 180ms ease;
  }

  .mobile-nav[open] .line-1 {
    transform: translateY(0.41rem) rotate(45deg);
  }

  .mobile-nav[open] .line-2 {
    opacity: 0;
  }

  .mobile-nav[open] .line-3 {
    transform: translateY(-0.41rem) rotate(-45deg);
  }

  .mobile-nav[open] .mobile-toggle {
    @apply text-violet-500 dark:text-violet-400;
  }

  .header-nav {
    animation: nav-appear 1s linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;
  }

  .header-nav {
    @apply dark:bg-gray-900/80 bg-white/60;
  }

  .nav-link.text-violet-500 {
    @apply font-semibold;
  }

  @keyframes nav-appear {
    0% {
      @apply dark:bg-gray-900/0 bg-white/0 border-transparent shadow-none;
    }
    to {
      @apply shadow-lg ring-1 backdrop-blur-md ring-white/10 dark:ring-white/5 border-gray-200/20 dark:border-white/5;
    }
  }
</style>
