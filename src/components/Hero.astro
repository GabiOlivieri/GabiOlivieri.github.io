---
const personalImageAlt = "Gabriel Olivieri"
import Badge from "@/components/Badge.astro"
import GitHubIcon from "@/components/icons/GitHub.astro"
import LinkedInIcon from "@/components/icons/LinkedIn.astro"
import MailIcon from "@/components/icons/Mail.astro"
import BriefcaseIcon from "@/components/icons/Briefcase.astro"
import SocialPill from "@/components/SocialPill.astro"
---

<div class="max-w-4xl mx-auto text-center">
  <div class="anim-fade-in flex justify-center gap-4 mb-6 items-center">
    <!-- Avatar with ambient glow -->
    <div class="relative flex-shrink-0">
      <div
        class="absolute inset-0 rounded-full bg-violet-400/30 dark:bg-sky-500/20 blur-xl scale-125"
        aria-hidden="true"
      >
      </div>
      <img
        class="relative rounded-full shadow-2xl w-32 h-32 object-cover object-center ring-2 ring-violet-400/60 ring-offset-2 ring-offset-gray-50 dark:ring-offset-gray-950"
        src="/IMG-20220928-WA0013-01.jpeg"
        alt={personalImageAlt}
      />
    </div>
  </div>

  <h1
    class="anim-fade-in anim-delay-1 text-4xl font-bold tracking-tight text-gray-800 sm:text-5xl dark:text-white"
  >
    <span data-i18n="hero.greeting">Hola, soy</span> <span class="gradient-name">Gabriel Olivieri</span>
  </h1>

  <p
    data-i18n-html="hero.descriptionHtml"
    class="anim-fade-in anim-delay-2 mt-6 text-xl text-gray-800 dark:[&>strong]:text-violet-200 [&>strong]:text-violet-500 [&>strong]:font-semibold dark:text-gray-300 max-w-4xl"
  >
  Soy <strong>Full stack Developer </strong>, especializado en crear soluciones digitales que combinan innovación técnica, adaptabilidad y un compromiso obsesivo con el valor para el usuario.<br>
  Lidero con el ejemplo, disfruto potenciando equipos y me meto de lleno en desafíos complejos donde la solución no está escrita.<br>
  Si tenés un proyecto ambicioso, <strong>hablemos.</strong>
  </p>

  <nav
    class="anim-fade-in anim-delay-4 flex flex-wrap justify-center gap-4 mt-8"
    aria-label="Redes sociales y contacto"
    data-i18n-attr="aria-label:hero.socialAria"
  >
    <SocialPill href="mailto:gabriel.olivieri@adini.com.ar">
      <MailIcon class="size-4" />
      <span data-i18n="hero.contact">Contacto</span>
    </SocialPill>
    <SocialPill href="https://www.linkedin.com/in/gabriel-olivieri-38437b1bb/">
      <LinkedInIcon class="size-4" />
      LinkedIn
    </SocialPill>
    <SocialPill href="https://github.com/GabiOlivieri">
      <GitHubIcon class="size-4" />
      GitHub
    </SocialPill>
    <Badge><BriefcaseIcon class="size-4" /> Upwork</Badge>
  </nav>

  <div class="anim-fade-in anim-delay-5 mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-3xl border border-slate-200/80 bg-slate-50/80 p-6 text-center shadow-sm backdrop-blur-sm dark:border-slate-700/70 dark:bg-slate-900/80">
      <span class="block text-sm uppercase tracking-[0.3em] text-slate-500" data-i18n="hero.years">Años en la industria</span>
      <p class="mt-3 text-4xl font-semibold text-violet-600 dark:text-violet-400">+5</p>
    </div>
    <div class="rounded-3xl border border-slate-200/80 bg-slate-50/80 p-6 text-center shadow-sm backdrop-blur-sm dark:border-slate-700/70 dark:bg-slate-900/80">
      <span class="block text-sm uppercase tracking-[0.3em] text-slate-500" data-i18n="hero.projects">Proyectos realizados</span>
      <p class="mt-3 text-4xl font-semibold text-sky-600 dark:text-sky-400">+8</p>
    </div>
  </div>
</div>
