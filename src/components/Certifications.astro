---

<div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
  {certifications.map((cert) => (
    <article class="rounded-[2rem] border border-slate-200/80 bg-gradient-to-b from-white/90 to-slate-50/70 p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md dark:border-slate-700/70 dark:from-slate-950/90 dark:to-slate-900/80">
      <div class="flex items-start gap-4">
        <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl border border-slate-200/80 bg-white dark:border-slate-700 dark:bg-slate-950">
          {cert.icon ? (
            <svg class="h-7 w-7" viewBox="0 0 24 24" aria-hidden="true" style={`color:#${cert.icon.hex}`}>
              <path fill="currentColor" d={cert.icon.path}></path>
            </svg>
          ) : cert.iconSvg ? (
            <div class="cert-inline-svg" set:html={cert.iconSvg} />
          ) : (
            <span class={`inline-flex items-center justify-center rounded-lg px-2 py-1 text-[11px] font-bold tracking-wide ${cert.iconTextClass ?? "bg-slate-900 text-white"}`}>
              {cert.iconText ?? "CERT"}
            </span>
          )}
        </div>
        <div class="min-w-0">
          <h3 class="text-base font-semibold text-slate-900 dark:text-slate-100">{cert.title}</h3>
          <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">{cert.issuer}</p>
          <p class="mt-2 text-xs uppercase tracking-[0.18em] text-slate-500 dark:text-slate-500">{cert.logoLabel}</p>
        </div>
      </div>

      {cert.certificateImage ? (
        <a href={cert.certificateImage} target="_blank" rel="noreferrer noopener" class="mt-5 block overflow-hidden rounded-2xl border border-slate-200/80 dark:border-slate-700">
          <img
            src={cert.certificateImage}
            alt={`Certificado de ${cert.title}`}
            loading="lazy"
            class="h-40 w-full object-cover object-top transition duration-300 hover:scale-[1.01]"
          />
        </a>
      ) : null}

      <div class="mt-5 grid gap-2 text-sm text-slate-700 dark:text-slate-300">
        <p><span class="font-medium" data-i18n="certifications.issued">Expedicion:</span> {cert.issuedAt}</p>
        {cert.expiresAt ? <p><span class="font-medium" data-i18n="certifications.expires">Vencimiento:</span> {cert.expiresAt}</p> : null}
        <p class="break-all"><span class="font-medium" data-i18n="certifications.credentialId">ID de la credencial:</span> {cert.credentialId}</p>
      </div>

      {cert.skills?.length ? (
        <div class="mt-4 flex flex-wrap gap-2">
          {cert.skills.map((skill) => (
            <span class="rounded-full border border-slate-200/80 bg-slate-100/80 px-2.5 py-1 text-xs font-medium text-slate-700 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300">
              {skill}
            </span>
          ))}
        </div>
      ) : null}

      <div class="mt-5">
        {cert.credentialUrl ? (
          <a
            href={cert.credentialUrl}
            target="_blank"
            rel="noreferrer noopener"
            class="inline-flex items-center rounded-xl border border-violet-300/80 bg-violet-50 px-3 py-2 text-sm font-medium text-violet-700 transition hover:bg-violet-100 dark:border-violet-500/50 dark:bg-violet-500/10 dark:text-violet-300 dark:hover:bg-violet-500/20"
          >
            <span data-i18n="certifications.showCredential">Mostrar credencial</span>
          </a>
        ) : (
          <span class="inline-flex items-center rounded-xl border border-slate-200/80 bg-slate-100/70 px-3 py-2 text-sm font-medium text-slate-500 dark:border-slate-700 dark:bg-slate-800/60 dark:text-slate-400">
            <span data-i18n="certifications.noPublicLink">Credencial sin enlace publico</span>
          </span>
        )}
      </div>
    </article>
  ))}
</div>

<style>
  .cert-inline-svg {
    width: 2.1rem;
    height: 2.1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .cert-inline-svg :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
