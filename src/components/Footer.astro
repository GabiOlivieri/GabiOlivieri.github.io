---
const currentYear = new Date().getFullYear()
const footerLinks = [
  { title: "Experiencia", href: "/#experiencia", i18nKey: "footer.experiencia" },
  { title: "Formación", href: "/#formacion", i18nKey: "footer.formacion" },
  { title: "Stack", href: "/#stack", i18nKey: "footer.stack" },
  { title: "Certificaciones", href: "/#certificaciones", i18nKey: "footer.certificaciones" },
  { title: "Proyectos", href: "/#proyectos", i18nKey: "footer.proyectos" },
  { title: "Blog", href: "/#blog", i18nKey: "footer.blog" },
]
---

<footer
  class="opacity-80 m-4 min-[375px]:pl-4 md:pl-0 mt-16 w-full mx-auto container lg:max-w-4xl md:max-w-2xl mb-10 flex justify-center"
>
  <div
    class="rounded-lg w-full max-w-screen-xl mx-auto md:flex md:items-center md:justify-between py-4"
  >
    <span class="text-sm sm:text-center text-zinc-800/90 dark:text-zinc-200/90 inline-flex items-center gap-1"
      >&copy; {currentYear}
      <a href="https://midu.dev/" class="hover:underline">Gabriel Olivieri</a>
    </span>
    <ul
      class="flex flex-wrap items-center mt-3 text-sm font-medium dark:text-white/90 sm:mt-0"
    >
      {
        footerLinks.map((link) => (
          <li>
            <a href={link.href} class="hover:underline me-4 md:me-6">
              <span data-i18n={link.i18nKey}>{link.title}</span>
            </a>
          </li>
        ))
      }
      <li>
        <a id="contacto" href="mailto:gabriel.olivieri@adini.com.ar" class="hover:underline"
          ><span data-i18n="footer.contact">Contacto</span></a
        >
      </li>
    </ul>
  </div>
</footer>
